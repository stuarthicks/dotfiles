// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "cursor": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "default_config_options": {
        "mode": "auto"
      },
      "type": "registry"
    }
  },
  "toolbar": {
    "code_actions": true
  },
  "which_key": {
    "enabled": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "format_on_save": "off",
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
    "use_modifier_to_send": true
  },
  "helix_mode": true,
  "restore_on_startup": "launchpad",
  "disable_ai": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "buffer_font_family": "Berkeley Mono",
  "buffer_font_features": {
    "calt": false
  },
  "theme": {
    "mode": "dark",
    "light": "Ember Light",
    "dark": "Ember"
  }
}
