{
  "$schema": "https://opencode.ai/theme.json",

  "defs": {
    "bgDark":        "#1c1b19",
    "bgDarkAlt":     "#242320",
    "baseDark2":     "#252422",
    "baseDark3":     "#2e2d2a",
    "baseDark4":     "#3e3c38",
    "baseDark6":     "#706c61",
    "baseDark7":     "#908a7e",
    "fgDark":        "#d8d0c0",
    "fgDarkAlt":     "#b0a898",

    "coralDark":     "#e08060",
    "orangeDark":    "#c09058",
    "goldDark":      "#c8b468",
    "oliveDark":     "#8a9868",
    "sageDark":      "#80a090",
    "steelDark":     "#7890a0",
    "roseDark":      "#b07878",
    "mauveDark":     "#988090",

    "diffAddBgDark":     "#2c2e25",
    "diffRemBgDark":     "#392a24",
    "diffAddGutterDark": "#25251f",
    "diffRemGutterDark": "#2c231f",

    "bgLight":       "#e6dac4",
    "bgLightAlt":    "#ddd0b8",
    "baseLight2":    "#d8ccb0",
    "baseLight3":    "#cec2a8",
    "baseLight4":    "#b8ac96",
    "baseLight6":    "#787060",
    "baseLight7":    "#605848",
    "fgLight":       "#282418",
    "fgLightAlt":    "#585040",

    "coralLight":    "#b84c30",
    "orangeLight":   "#946030",
    "goldLight":     "#7a6820",
    "oliveLight":    "#4a6830",
    "sageLight":     "#386858",
    "steelLight":    "#3a6080",
    "roseLight":     "#905050",
    "mauveLight":    "#706070",

    "diffAddBgLight":     "#cec9ae",
    "diffRemBgLight":     "#dfc5ae",
    "diffAddGutterLight": "#dad1b8",
    "diffRemGutterLight": "#e2cfb8"
  },

  "theme": {
    "primary":           { "dark": "coralDark",  "light": "coralLight"  },
    "secondary":         { "dark": "goldDark",   "light": "goldLight"   },
    "accent":            { "dark": "sageDark",   "light": "sageLight"   },
    "error":             { "dark": "roseDark",   "light": "roseLight"   },
    "warning":           { "dark": "goldDark",   "light": "goldLight"   },
    "success":           { "dark": "oliveDark",  "light": "oliveLight"  },
    "info":              { "dark": "steelDark",  "light": "steelLight"  },

    "text":              { "dark": "fgDark",     "light": "fgLight"     },
    "textMuted":         { "dark": "fgDarkAlt",  "light": "fgLightAlt"  },
    "background":        "none",
    "backgroundPanel":   { "dark": "bgDarkAlt",  "light": "bgLightAlt"  },
    "backgroundElement": { "dark": "baseDark2",  "light": "baseLight2"  },
    "border":            { "dark": "baseDark4",  "light": "baseLight4"  },
    "borderActive":      { "dark": "coralDark",  "light": "coralLight"  },
    "borderSubtle":      { "dark": "baseDark3",  "light": "baseLight3"  },

    "diffAdded":              { "dark": "oliveDark",        "light": "oliveLight"        },
    "diffRemoved":            { "dark": "coralDark",        "light": "coralLight"        },
    "diffContext":            { "dark": "baseDark6",        "light": "baseLight6"        },
    "diffHunkHeader":         { "dark": "steelDark",        "light": "steelLight"        },
    "diffHighlightAdded":     { "dark": "oliveDark",        "light": "oliveLight"        },
    "diffHighlightRemoved":   { "dark": "coralDark",        "light": "coralLight"        },
    "diffAddedBg":            { "dark": "diffAddBgDark",    "light": "diffAddBgLight"    },
    "diffRemovedBg":          { "dark": "diffRemBgDark",    "light": "diffRemBgLight"    },
    "diffContextBg":          { "dark": "bgDarkAlt",        "light": "bgLightAlt"        },
    "diffLineNumber":         { "dark": "baseDark6",        "light": "baseLight6"        },
    "diffAddedLineNumberBg":  { "dark": "diffAddGutterDark","light": "diffAddGutterLight"},
    "diffRemovedLineNumberBg":{ "dark": "diffRemGutterDark","light": "diffRemGutterLight"},

    "markdownText":           { "dark": "fgDark",     "light": "fgLight"     },
    "markdownHeading":        { "dark": "coralDark",  "light": "coralLight"  },
    "markdownLink":           { "dark": "sageDark",   "light": "sageLight"   },
    "markdownLinkText":       { "dark": "steelDark",  "light": "steelLight"  },
    "markdownCode":           { "dark": "goldDark",   "light": "goldLight"   },
    "markdownBlockQuote":     { "dark": "fgDarkAlt",  "light": "fgLightAlt"  },
    "markdownEmph":           { "dark": "mauveDark",  "light": "mauveLight"  },
    "markdownStrong":         { "dark": "orangeDark", "light": "orangeLight" },
    "markdownHorizontalRule": { "dark": "baseDark6",  "light": "baseLight6"  },
    "markdownListItem":       { "dark": "coralDark",  "light": "coralLight"  },
    "markdownListEnumeration":{ "dark": "orangeDark", "light": "orangeLight" },
    "markdownImage":          { "dark": "sageDark",   "light": "sageLight"   },
    "markdownImageText":      { "dark": "steelDark",  "light": "steelLight"  },
    "markdownCodeBlock":      { "dark": "fgDark",     "light": "fgLight"     },

    "syntaxComment":     { "dark": "baseDark6",  "light": "baseLight6"  },
    "syntaxKeyword":     { "dark": "coralDark",  "light": "coralLight"  },
    "syntaxFunction":    { "dark": "goldDark",   "light": "goldLight"   },
    "syntaxVariable":    { "dark": "fgDark",     "light": "fgLight"     },
    "syntaxString":      { "dark": "oliveDark",  "light": "oliveLight"  },
    "syntaxNumber":      { "dark": "orangeDark", "light": "orangeLight" },
    "syntaxType":        { "dark": "goldDark",   "light": "goldLight"   },
    "syntaxOperator":    { "dark": "baseDark7",  "light": "baseLight7"  },
    "syntaxPunctuation": { "dark": "fgDark",     "light": "fgLight"     }
  }
}
