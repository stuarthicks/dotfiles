            <dict>
                <key>foreground</key>
                <string>#b84c30</string>
                <key>fontStyle</key>
                <string>italic</string>
            </dict>
        </dict>

        <!-- ─── Functions ─────────────────────────────────────────────────── -->
        <dict>
            <key>name</key>
