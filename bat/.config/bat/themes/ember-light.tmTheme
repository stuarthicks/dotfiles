                <string>#b84c30</string>
            </dict>
        </dict>

        <!-- ─── Types &amp; Classes ──────────────────────────────────────────── -->
        <!-- Built-in primitives: string, int, bool, void, char, …
             Sublime's older Go syntax tags these as `support.type.*` — gold,
             non-bold to distinguish from the declaration keywords above. -->
        <dict>
            <key>name</key>
            <string>Built-in primitive types (int, string, bool, void)</string>
            <key>scope</key>
            <string>support.type, support.type.primitive, support.type.built-in</string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#7a6820</string>
            </dict>
        </dict>
        <!-- Named types and classes — these often co-scope as `storage.type`,
             so we list them AFTER storage to win the tiebreak in syntect. -->
        <dict>
            <key>name</key>
            <string>Named type / class definition</string>
            <key>scope</key>
            <string>entity.name.type, entity.name.class, entity.name.type.class, support.class</string>
