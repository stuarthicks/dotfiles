        <!-- ─── Keywords &amp; Storage ────────────────────────────────────────
             NOTE: bat 0.26.1's bundled Go syntax scopes declaration keywords
             (func, type, struct, const, var, package, import) as
             `storage.type.*.go` rather than `keyword.declaration.*`. We
             therefore color all of `storage` and `storage.type` as the coral
             hero accent; named types and built-ins still differentiate via
             more-specific rules placed LATER in this file.
        ────────────────────────────────────────────────────────────────────── -->
        <dict>
            <key>name</key>
            <string>Keyword (control flow: if/for/while/return)</string>
            <key>scope</key>
            <string>keyword, keyword.control, keyword.other</string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#b84c30</string>
                <key>fontStyle</key>
                <string>bold</string>
            </dict>
        </dict>
        <dict>
            <key>name</key>
            <string>Keyword operator (===, &amp;&amp;, !=, …)</string>
            <key>scope</key>
            <string>keyword.operator</string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#605848</string>
            </dict>
        </dict>
        <dict>
            <key>name</key>
            <string>Storage / declaration keywords (func, type, struct, const, var, …)</string>
